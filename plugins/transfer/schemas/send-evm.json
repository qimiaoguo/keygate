{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "chain": {
      "type": "string",
      "enum": ["ethereum", "polygon", "arbitrum", "bsc"],
      "description": "Target EVM chain"
    },
    "to": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$",
      "description": "Recipient address"
    },
    "token": {
      "type": "string",
      "description": "Token symbol or address. Use 'ETH'/'MATIC'/'BNB' for native."
    },
    "amount": {
      "type": "number",
      "minimum": 0,
      "exclusiveMinimum": 0,
      "description": "Amount in human-readable units"
    }
  },
  "required": ["chain", "to", "token", "amount"],
  "additionalProperties": false
}
