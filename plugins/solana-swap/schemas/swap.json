{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "from_token": {
      "type": "string",
      "description": "Source token mint address or symbol (SOL, USDC, etc.)"
    },
    "to_token": {
      "type": "string",
      "description": "Destination token mint address or symbol"
    },
    "amount": {
      "type": "number",
      "minimum": 0,
      "exclusiveMinimum": 0,
      "description": "Amount in human-readable units"
    },
    "slippage": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 50,
      "default": 1,
      "description": "Max slippage percentage"
    }
  },
  "required": ["from_token", "to_token", "amount"],
  "additionalProperties": false
}
